# Server Environment Variables
NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/blueprint-lab

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# 이미지 업로드 경로 (로컬: 미설정 시 ./upload 사용, 운영: /app/upload 등)
# UPLOAD_DIR=/app/upload

# 관리자 이메일 (쉼표 구분, 관리자 페이지 접근 권한)
ADMIN_EMAILS=myljk1025@gmail.com
